# =========================================
# Minlish Servers - ENV mẫu (an toàn để commit)
# =========================================
# Cách dùng:
# 1) Copy file này thành .env
# 2) Điền giá trị thật của bạn
# 3) KHÔNG commit file .env thật lên GitHub

# URL frontend để backend redirect sau đăng nhập OAuth2 (Google/GitHub)
# Local frontend hiện tại: http://localhost:2910
UI_URL=http://localhost:2910

# Cổng backend
PORT=8080

# MySQL
# Định dạng: jdbc:mysql://host:port/database?useSSL=false&serverTimezone=Asia/Bangkok
DB_URL=jdbc:mysql://localhost:3306/minlish?useSSL=false&serverTimezone=Asia/Bangkok
DB_USERNAME=your_mysql_username
DB_PASSWORD=your_mysql_password

# JWT
# Secret nên là chuỗi ngẫu nhiên dài >= 64 ký tự
JWT_SECRET=replace_with_a_long_random_secret_key
# Thời hạn token tính bằng milliseconds
JWT_EXPIRATION=604800000
JWT_REFRESH_EXPIRATION=2592000000

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth2 (nếu dùng)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# SMTP gửi email
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-mail-app-password

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
